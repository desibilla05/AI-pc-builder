# Secure Port for Backend Service
PORT=3001

# Allowed Origin (Frontend React App URL)
FRONTEND_URL=http://localhost:5173

# Secret API Key for Gemini API (Never expose this in the client)
GEMINI_API_KEY=

# Secret key for signing JSON Web Tokens (JWT) - minimum 32 characters
JWT_SECRET=

# Connection URI for MongoDB Atlas (Optional: falls back to local JSON database if empty)
MONGODB_URI=
